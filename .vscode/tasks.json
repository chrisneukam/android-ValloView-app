{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Gradle Build",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew",
      "windows": {
        "command": "${workspaceFolder}\\gradlew.bat"
      },
      "args": [
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gradle"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "detail": "Build the app using Gradle"
    },
    {
      "label": "Format with ktlint",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew",
      "windows": {
        "command": "${workspaceFolder}\\gradlew.bat"
      },
      "args": [
        "ktlintFormat"
      ],
      "problemMatcher": [
        "$gradle"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "detail": "Format Kotlin code by running ktlintFormat"
    },
    {
      "label": "Execute Unit Tests",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew",
      "windows": {
        "command": "${workspaceFolder}\\gradlew.bat"
      },
      "args": [
        "test"
      ],
      "problemMatcher": [
        "$gradle"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "detail": "Execute unit tests"
    },
    {
      "label": "Generate Dokka docs",
      "type": "shell",
      "command": "${workspaceFolder}/gradlew",
      "windows": {
        "command": "${workspaceFolder}\\gradlew.bat"
      },
      "args": [
        ":app:dokkaGenerate"
      ],
      "problemMatcher": [
        "$gradle"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "detail": "Generate documentation using Dokka"
    },
    {
      "label": "Dokka: Serve Docs",
      "type": "shell",
      "command": "python -m http.server 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Serving HTTP",
          "endsPattern": "Serving HTTP"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "detail": "Serve Dokka documentation on http://localhost:8000"
    }
  ]
}